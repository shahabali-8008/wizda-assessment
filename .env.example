PORT=3000
NODE_ENV=development

# SQLite file (absolute or relative to cwd). Tests use :memory: via env in jest config.
DATABASE_PATH=data/timeoff.sqlite

# Schema changes: use migrations (`npm run migration:generate` / `migration:run`). Set true only for quick local experiments — not production-grade.
TYPEORM_SYNC=false

# Apply pending migrations when the app starts (set false in production if you run migrations in CI/deploy instead)
TYPEORM_MIGRATIONS_RUN=true

# Optional API auth: when set, GraphQL requires `X-Api-Key: <value>` or `Authorization: Bearer <value>`.
# Leave unset for local dev / tests. `GET /health` stays public.
# API_KEY=

# HCM integration: omit = in-process MockHcmService; set = HTTP client (see mock-hcm-server/)
# HCM_BASE_URL=http://127.0.0.1:3099

# Mock HCM (in-process or HTTP server — same semantics)
# HCM_FORCE_REJECT=true          # submitDeduction always fails
# HCM_SILENT_BAD_SUCCESS=true     # success response but no deduction (defensive path after manager approve)
# HCM_SIMULATE_TIMEOUT=true       # throws 503 on each HCM call

# Standalone mock HTTP server only:
# MOCK_HCM_PORT=3099
